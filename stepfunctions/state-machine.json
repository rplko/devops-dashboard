{
  "Comment": "Devops Dashboard Deployment Pipeline — with SSM deployments",
  "StartAt": "Staging Health Check",
  "States": {

    "Staging Health Check": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:029139774327:function:devops-dashboard-health-check",
      "Parameters": {
        "health_url": "http://44.222.215.213:3000/health",
        "environment": "staging"
      },
      "Next": "Send DC Approval Email",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "Notify Failure",
          "ResultPath": "$.error"
        }
      ],
      "Retry": [
        {
          "ErrorEquals": ["States.ALL"],
          "IntervalSeconds": 5,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ]
    },

    "Send DC Approval Email": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke.waitForTaskToken",
      "Parameters": {
        "FunctionName": "devops-dashboard-approval-email",
        "Payload": {
          "TaskToken.$": "$$.Task.Token",
          "Message": "Staging is healthy. Approve to deploy to DC.",
          "Environment": "dc"
        }
      },
      "Next": "Deploy to DC",
      "TimeoutSeconds": 86400,
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "Notify Failure",
          "ResultPath": "$.error"
        }
      ]
    },

    "Deploy to DC": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:029139774327:function:devops-dashboard-deploy-ssm",
      "Parameters": {
        "environment": "dc",
        "branch": "main"
      },
      "Next": "DC Health Check",
      "ResultPath": "$.dcDeploy",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "Notify DC Failure",
          "ResultPath": "$.error"
        }
      ],
      "Retry": [
        {
          "ErrorEquals": ["States.TaskFailed"],
          "IntervalSeconds": 10,
          "MaxAttempts": 2,
          "BackoffRate": 2
        }
      ]
    },

    "DC Health Check": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:029139774327:function:devops-dashboard-health-check",
      "Parameters": {
        "health_url": "http://98.92.57.61:3000/health",
        "environment": "dc"
      },
      "Next": "Notify DC Success",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "Notify DC Failure",
          "ResultPath": "$.error"
        }
      ],
      "Retry": [
        {
          "ErrorEquals": ["States.ALL"],
          "IntervalSeconds": 10,
          "MaxAttempts": 5,
          "BackoffRate": 2
        }
      ]
    },

    "Notify DC Success": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:029139774327:function:devops-dashboard-notify",
      "Parameters": {
        "status": "success",
        "environment": "dc",
        "message": "DC deployment completed successfully via SSM"
      },
      "Next": "Send Production Approval Email",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "Send Production Approval Email",
          "ResultPath": "$.error"
        }
      ]
    },

    "Notify DC Failure": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:029139774327:function:devops-dashboard-notify",
      "Parameters": {
        "status": "failed",
        "environment": "dc",
        "message": "DC deployment or health check failed"
      },
      "Next": "Notify Failure"
    },

    "Send Production Approval Email": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke.waitForTaskToken",
      "Parameters": {
        "FunctionName": "devops-dashboard-approval-email",
        "Payload": {
          "TaskToken.$": "$$.Task.Token",
          "Message": "DC is healthy. Approve to deploy to Production.",
          "Environment": "production"
        }
      },
      "Next": "Deploy to Production",
      "TimeoutSeconds": 86400,
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "Notify Failure",
          "ResultPath": "$.error"
        }
      ]
    },

    "Deploy to Production": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:029139774327:function:devops-dashboard-deploy-ssm",
      "Parameters": {
        "environment": "production",
        "branch": "main"
      },
      "Next": "Production Health Check",
      "ResultPath": "$.prodDeploy",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "Notify Production Failure",
          "ResultPath": "$.error"
        }
      ],
      "Retry": [
        {
          "ErrorEquals": ["States.TaskFailed"],
          "IntervalSeconds": 10,
          "MaxAttempts": 2,
          "BackoffRate": 2
        }
      ]
    },

    "Production Health Check": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:029139774327:function:devops-dashboard-health-check",
      "Parameters": {
        "health_url": "http://98.92.57.61:3000/health",
        "environment": "production"
      },
      "Next": "Notify Success",
      "Catch": [
        {
          "ErrorEquals": ["States.ALL"],
          "Next": "Notify Production Failure",
          "ResultPath": "$.error"
        }
      ],
      "Retry": [
        {
          "ErrorEquals": ["States.ALL"],
          "IntervalSeconds": 10,
          "MaxAttempts": 5,
          "BackoffRate": 2
        }
      ]
    },

    "Notify Success": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:029139774327:function:devops-dashboard-notify",
      "Parameters": {
        "status": "success",
        "environment": "production",
        "message": "Deployment completed successfully across all environments via SSM"
      },
      "End": true
    },

    "Notify Production Failure": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:029139774327:function:devops-dashboard-notify",
      "Parameters": {
        "status": "failed",
        "environment": "production",
        "message": "Production deployment or health check failed"
      },
      "Next": "Notify Failure"
    },

    "Notify Failure": {
      "Type": "Task",
      "Resource": "arn:aws:lambda:us-east-1:029139774327:function:devops-dashboard-notify",
      "Parameters": {
        "status": "failed",
        "environment": "unknown",
        "message": "Deployment pipeline failed — check CloudWatch logs for details"
      },
      "End": true
    }

  }
}